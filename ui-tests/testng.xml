<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="UI Test Suites" parallel="methods" thread-count="4">
  <test name="UI Smoke">
    <groups>
      <run>
        <include name="smoke"/>
      </run>
    </groups>
    <packages>
      <package name="com.quickiee.ui.tests"/>
    </packages>
  </test>

  <test name="UI Regression">
    <groups>
      <run>
        <include name="regression"/>
      </run>
    </groups>
    <packages>
      <package name="com.quickiee.ui.tests"/>
    </packages>
  </test>
</suite>
